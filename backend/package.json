    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.5",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "react-calendar": "^6.0.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5"
