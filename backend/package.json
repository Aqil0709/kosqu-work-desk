{
  "name": "backend",
  "version": "1.0.0",
  "description": "Feature-based production-ready Express + MySQL backend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --testPathPattern=tests/ --forceExit --detectOpenHandles",
    "db:backup": "node src/scripts/db-backup.js",
    "db:cleanup": "node src/scripts/db-cleanup.js",
    "db:cleanup:force": "node src/scripts/db-cleanup.js --force",
    "db:cleanup:dry": "node src/scripts/db-cleanup.js --dry-run",
    "db:seed": "node src/scripts/db-seed.js",
    "db:rollback": "node src/scripts/db-rollback.js",
    "db:rollback:list": "node src/scripts/db-rollback.js --list",
    "prod:backup": "node src/scripts/db-backup.js",
    "prod:cleanup:dry": "node src/scripts/prod-cleanup.js --dry-run",
    "prod:cleanup": "node src/scripts/prod-cleanup.js",
    "prod:cleanup:force": "node src/scripts/prod-cleanup.js --force",
    "prod:verify": "node src/scripts/prod-verify.js",
    "prod:rollback": "node src/scripts/db-rollback.js",
    "prod:rollback:list": "node src/scripts/db-rollback.js --list"
