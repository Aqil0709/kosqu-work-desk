  "keywords": [
    "express",
    "mysql",
    "feature-based"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "bcryptjs": "^3.0.3",
